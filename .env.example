# BloomoryAI Backend — copy to .env and fill in values.
# See docs/ENV_VARIABLES.md for details.

# Database
MONGO_URI=mongodb://localhost:27017/bloomory
DATABASE_URL=postgresql://user:password@localhost:5432/bloomory
USE_POSTGRES=true
SKIP_PG=
SKIP_DB=
PG_POOL_MAX=10

# Auth
JWT_SECRET=your-jwt-secret

# Redis (cache, BullMQ, timeline, WebSocket)
REDIS_URL=redis://localhost:6379

# Bunny Storage (images)
BUNNY_STORAGE_ZONE=your-storage-zone
BUNNY_STORAGE_KEY=your-storage-api-key
BUNNY_CDN_BASE_URL=https://yourzone.b-cdn.net

# Bunny Stream (videos)
BUNNY_STREAM_LIBRARY_ID=
BUNNY_STREAM_API_KEY=

# OpenAI (AI assistant)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
AI_MAX_OUTPUT_TOKENS=1024
AI_RATE_WINDOW_MS=60000
AI_RATE_MAX=30

# App
PORT=4000
NODE_ENV=development
CORS_ORIGIN=*
